# ---------------------------------------------------------------
# stx-swing-analyzer — Konfiguration
# Kopieren nach .env und anpassen. Pflichtfelder: POSTGRES_PASSWORD,
# SECRET_KEY, LLM_* (mind. ein Provider).
# ---------------------------------------------------------------

# --- Infrastruktur ---
POSTGRES_USER=stx
POSTGRES_PASSWORD=change-me
POSTGRES_DB=stx
# Einziger veröffentlichter Port — alles andere (Backend, DB, Redis)
# bleibt Docker-intern. API/Swagger via Frontend-Proxy: /api/docs
FRONTEND_PORT=5800

# Session-Cookie-Signierung (zufällig generieren: openssl rand -hex 32)
SECRET_KEY=change-me-random

# --- Auth ---
# AUTH_MODE: "none" (Dev, kein Login) | "oidc" (SSO, Produktion)
AUTH_MODE=none
# OIDC (bei AUTH_MODE=oidc): Discovery-Basis-URL des IdP (Keycloak-Realm,
# Authentik-Provider, ...) — /.well-known/openid-configuration wird ergänzt.
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Muss auf das Frontend zeigen (Next proxied /api → Backend):
OIDC_REDIRECT_URI=http://localhost:5800/api/auth/callback
# Komma-getrennte Liste erlaubter E-Mail-Adressen (Single-User-Gate)
ALLOWED_EMAILS=christian.hammann@gmail.com

# --- LLM ---
# LLM_PROVIDER: "openai" (OpenAI-kompatibel: OpenAI, vLLM, Ollama, OpenRouter, ...)
#             | "anthropic"
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# LLM-Antwort-Cache (Redis), Sekunden. 0 = aus.
LLM_CACHE_TTL=86400
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.2

# --- Marktdaten ---
# Primärquelle Yahoo Finance (yfinance, kein Key nötig).
# Optional Alpha Vantage als Fallback (25 Requests/Tag im Free-Tier!):
ALPHA_VANTAGE_API_KEY=

# --- Scheduler-Intervalle (Minuten) ---
FETCH_MARKET_INTERVAL_MIN=60
FETCH_NEWS_INTERVAL_MIN=30
ANALYZE_INTERVAL_MIN=120
# Universum-Screener (Top-Signale, rein technisch, ohne LLM-Kosten)
SCAN_INTERVAL_MIN=360
# Neues Signal frühestens nach X Stunden erneut erzeugen (außer Richtungswechsel)
SIGNAL_REFRESH_HOURS=24

# --- Signal-Scoring-Gewichte (Summe sollte 1.0 sein) ---
SCORE_WEIGHT_TECHNICAL=0.5
SCORE_WEIGHT_SENTIMENT=0.3
SCORE_WEIGHT_FUNDAMENTAL=0.2
# Composite-Schwelle für BUY/SELL (Aktien/ETFs)
SCORE_THRESHOLD=0.35
# Höhere Schwelle für Krypto (mehr Grundrauschen im 24/7-Markt).
# RSI-Schwellen (25/75) und MACD-Normierung des Krypto-Profils sind
# in backend/app/analysis/scoring.py (PROFILES) definiert.
SCORE_THRESHOLD_CRYPTO=0.45

# --- Daten-Retention (Tage) ---
# Kursdaten älter als das Fenster werden gelöscht (TimescaleDB-Policy).
# Erhöhen = längere Charts (neue Assets sofort, Bestand wächst täglich);
# Verringern LÖSCHT ältere Daten unwiderruflich. Änderungen greifen beim
# nächsten Container-Start.
RETENTION_OHLCV_DAYS=730
RETENTION_NEWS_DAYS=365

# --- MCP-Server ---
# Statisches Token für externe LLM-Agenten via /api/mcp (Streamable HTTP).
# Leer = MCP-Endpunkt deaktiviert. Generieren: openssl rand -hex 24
# Header: x-stx-token ODER Authorization: Bearer <token>
MCP_TOKEN=

# --- Alerts ---
# Telegram: Bot via @BotFather anlegen, Chat-ID z.B. via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# E-Mail (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=
